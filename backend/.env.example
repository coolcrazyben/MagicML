# Copy this file to .env and fill in your values.
# Set these as environment variables in Railway for production.

# Path to the SQLite card + combo database (built by build_card_db.py / build_combo_db.py)
COMBO_DB_PATH=cards.db

# Path to the trained XGBoost combo-speed model (built by ml_trainer.py)
MODEL_PATH=data/combo_speed_model.json

# Path to the trained XGBoost deck-quality model (built by deck_builder.py)
DECK_BUILDER_MODEL_PATH=data/deck_builder_model.json

# Directory used by ml_trainer.py to cache Scryfall card data
SCRYFALL_CACHE_DIR=data/cards
